{
  "name": "improvement",
  "version": "0.1.0",
  "description": "Desktop-first AI mentor workspace for deep technical mastery.",
  "private": true,
  "type": "commonjs",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "pnpm run rebuild:native && node scripts/electron-vite.mjs dev",
    "build": "tsc --noEmit -p tsconfig.json && pnpm run rebuild:native && electron-vite build",
    "preview": "pnpm run rebuild:native && node scripts/electron-vite.mjs preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "pnpm rebuild better-sqlite3",
    "test": "pnpm run rebuild:node && vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.3.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
